# Required ONLY for the AI-powered features (ProAdvisor Chat, Coach Alex, CPA AI,
# resume/proposal/SOP/diagnostic generators, bank-feed AI, statement converter, etc.).
# Everything else (calculators, checklists, Chart of Accounts, templates) runs without it.
#
# 1. Get a key at https://console.anthropic.com/
# 2. Copy this file to `.env` and paste your key below
# 3. Run `npm run dev`
#
# The key is used ONLY by the Vite dev proxy (vite.config.js) and is never sent to the browser.

ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Supabase (user authentication — signup / login). Required for the auth gate.
# ---------------------------------------------------------------------------
# 1. Create a free project at https://supabase.com/
# 2. Project Settings -> API -> copy the "Project URL" and the "anon public" key
# 3. Paste them below in `.env`, then run `npm run dev`
#
# NOTE: unlike ANTHROPIC_API_KEY, these MUST be `VITE_`-prefixed so Vite exposes
# them to the browser at build time. The anon key is PUBLIC by design — it is safe
# in the client bundle. Real security is enforced by Supabase Row Level Security
# (RLS) policies on the database, NOT by hiding this key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
