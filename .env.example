# Required ONLY for the AI-powered features (ProAdvisor Chat, Coach Alex, CPA AI,
# resume/proposal/SOP/diagnostic generators, bank-feed AI, statement converter, etc.).
# Everything else (calculators, checklists, Chart of Accounts, templates) runs without it.
#
# 1. Get a key at https://console.anthropic.com/
# 2. Copy this file to `.env` and paste your key below
# 3. Run `npm run dev`
#
# The key is used ONLY by the Vite dev proxy (vite.config.js) and is never sent to the browser.

ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Supabase (user authentication — signup / login). Required for the auth gate.
# ---------------------------------------------------------------------------
# 1. Create a free project at https://supabase.com/
# 2. Project Settings -> API -> copy the "Project URL" and the "anon public" key
# 3. Paste them below in `.env`, then run `npm run dev`
#
# NOTE: unlike ANTHROPIC_API_KEY, these MUST be `VITE_`-prefixed so Vite exposes
# them to the browser at build time. The anon key is PUBLIC by design — it is safe
# in the client bundle. Real security is enforced by Supabase Row Level Security
# (RLS) policies on the database, NOT by hiding this key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Temporary admin-approval gate (new signups need admin approval) — see
# ADMIN_APPROVAL_SETUP.md. The feature is ON by default once you run the SQL
# migration (db/2026-06-29-user-approval.sql). These vars are all OPTIONAL.
# ---------------------------------------------------------------------------
# Turn the whole gate OFF later (open access) without a code change. Default is ON;
# set to false (and rebuild) to disable. VITE_-prefixed because the client reads it.
VITE_REQUIRE_ADMIN_APPROVAL=

# ---------------------------------------------------------------------------
# Notification EMAILS (optional) — powers BOTH the admin-approval approve/reject
# emails (api/notify-access.js) AND the enrollment/payment emails
# (api/notify-enrollment.js: "new enrollment submitted" admin alert, student
# approve/reject/expired, and the admin "Test email" button). Server-only.
# ---------------------------------------------------------------------------
# ⚠️ IMPORTANT — these run as VERCEL SERVERLESS FUNCTIONS. `npm run dev` (Vite) does
#    NOT run them, so email can only be tested on a Vercel deploy (Preview or Prod),
#    NEVER on the local dev server. Set these in Vercel → Settings → Environment
#    Variables (Production + Preview), then Redeploy. Without them, everything still
#    works — the app just shows "email not configured".
#
# ⚠️ Resend only DELIVERS from an allowed sender: verify a domain in Resend and use it
#    in RESEND_FROM (recommended — reaches admins AND students), or use the test sender
#    "onboarding@resend.dev" which only delivers to your own Resend-account email.
#    The API key must belong to the account that owns the verified domain.
#
# Server-only — do NOT add a VITE_ prefix and never expose these in the browser.
#   RESEND_API_KEY      — your Resend key (re_…); may reuse the one from the Supabase SMTP setup
#                         (but it must still be added HERE in Vercel — Supabase's copy is separate)
#   RESEND_FROM         — a verified sender, e.g. "Toolkits by Alex <noreply@yourdomain.com>"
#   NOTIFY_ADMIN_EMAIL  — (optional) where the "new enrollment submitted" alert lands; if unset,
#                         falls back to payment_settings.notify_email, then to RESEND_FROM's address
#   APP_URL             — (optional) absolute origin for the "Review in Enrollments" button,
#                         e.g. https://toolkits.alexsagun.com (defaults to the request host)
RESEND_API_KEY=
RESEND_FROM=
NOTIFY_ADMIN_EMAIL=
APP_URL=
